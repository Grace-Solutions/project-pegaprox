[Unit]
Description=PegaProx - Proxmox Datacenter Manager for Proxmox VE
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pegaprox
Group=pegaprox
WorkingDirectory=/var/lib/pegaprox
ExecStart=/usr/bin/pegaprox/pegaprox-wrapper

Restart=on-failure
RestartSec=5

AmbientCapabilities=CAP_NET_BIND_SERVICE
PrivateTmp=true
NoNewPrivileges=true

StandardOutput=journal
StandardError=journal
SyslogIdentifier=pegaprox

[Install]
WantedBy=multi-user.target